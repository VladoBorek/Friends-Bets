{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pb138/shared": ["./shared/src/index.ts"],
      "@pb138/shared/*": ["./shared/src/*"]
    }
  },
  "include": ["server/src", "server/scripts", "shared/src"]
}
